# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taskflow
DEBUG=false

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=taskflow-api
JWT_AUDIENCE=taskflow-client

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Mail provider / Mailtrap
MAIL_USERNAME=your-mail-username
MAIL_PASSWORD=your-mail-password
MAIL_FROM=noreply@example.com
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
DOMAIN=http://localhost:8000

# Deployment / frontend access
FRONTEND_ORIGINS=http://localhost:5173
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
ALLOWED_HOSTS=localhost,127.0.0.1,test,testserver,*.onrender.com
